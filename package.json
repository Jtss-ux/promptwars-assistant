{
  "name": "logicflow-code-review-assistant",
  "version": "1.0.0",
  "description": "LogicFlow: AI-powered Code Review Assistant built with Google Gemini and Vertex AI. Context-aware developer support for code review, architecture design, and debugging.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test app.test.js",
    "test:watch": "node --test --watch app.test.js",
    "test:coverage": "node --test --experimental-test-coverage app.test.js",
    "lint": "eslint server.js app.test.js src/",
    "lint:fix": "eslint --fix server.js app.test.js src/",
    "size": "git ls-files | ForEach-Object { (Get-Item $_).Length } | Measure-Object -Sum"
  },
  "keywords": [
    "gemini",
    "vertex-ai",
    "code-review",
    "ai-assistant",
    "cloud-run",
    "google-cloud",
    "firestore",
    "secret-manager",
    "cloud-monitoring",
    "promptwars",
    "hackathon"
  ],
  "author": "LogicFlow Team",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google-cloud/error-reporting": "^3.0.5",
    "@google-cloud/firestore": "^8.5.0",
    "@google-cloud/monitoring": "^5.3.1",
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/vertexai": "^1.11.0",
    "@google/genai": "^1.50.0",
    "compression": "^1.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  }
}
